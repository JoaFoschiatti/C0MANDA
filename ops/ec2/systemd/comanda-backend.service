[Unit]
Description=Comanda Backend
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/comanda/backend
EnvironmentFile=/opt/comanda/backend/.env
Environment=NODE_ENV=production
Environment=UPLOADS_DIR=/opt/comanda/uploads
ExecStart=/usr/bin/node src/server.js
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
