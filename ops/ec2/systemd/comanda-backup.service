[Unit]
Description=Comanda backup diario a S3
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=www-data
Group=www-data
WorkingDirectory=/opt/comanda
EnvironmentFile=/opt/comanda/backend/.env
ExecStart=/bin/bash /opt/comanda/ops/ec2/scripts/backup-db.sh
ExecStopPost=/bin/bash /opt/comanda/ops/ec2/scripts/notify-failure.sh backup
