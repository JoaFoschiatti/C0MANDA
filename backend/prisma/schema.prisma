generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Rol {
  ADMIN
  MOZO
  COCINERO
  CAJERO
  DELIVERY
}

enum EstadoMesa {
  LIBRE
  OCUPADA
  RESERVADA
  ESPERANDO_CUENTA
  CERRADA
}

enum TipoPedido {
  MESA
  DELIVERY
  MOSTRADOR
  ONLINE
}

enum EstadoPedido {
  PENDIENTE
  EN_PREPARACION
  LISTO
  ENTREGADO
  COBRADO
  CERRADO
  CANCELADO
}

enum MetodoPago {
  EFECTIVO
  MERCADOPAGO
  TARJETA
}

enum CanalCobro {
  CAJA
  CHECKOUT_WEB
  QR_PRESENCIAL
}

enum TipoMovimientoStock {
  ENTRADA
  SALIDA
  AJUSTE
}

enum EstadoPago {
  PENDIENTE
  APROBADO
  RECHAZADO
  CANCELADO
}

enum TipoEntrega {
  DELIVERY
  RETIRO
}

enum OrigenPedido {
  INTERNO
  MENU_PUBLICO
}

enum TipoComanda {
  COCINA
  CAJA
  CLIENTE
}

enum EstadoPrintJob {
  PENDIENTE
  IMPRIMIENDO
  OK
  ERROR
}

enum EstadoCaja {
  ABIERTO
  CERRADO
}

enum EstadoReserva {
  CONFIRMADA
  CLIENTE_PRESENTE
  NO_LLEGO
  CANCELADA
}

enum TipoModificador {
  EXCLUSION
  ADICION
}

model Negocio {
  id              Int      @id @default(1)
  nombre          String
  email           String
  telefono        String?
  direccion       String?
  logo            String?
  bannerUrl       String?
  colorPrimario   String?  @default("#3B82F6")
  colorSecundario String?  @default("#1E40AF")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("negocios")
}

model Usuario {
  id            Int              @id @default(autoincrement())
  email         String           @unique
  password      String
  nombre        String
  rol           Rol              @default(MOZO)
  activo        Boolean          @default(true)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  pedidos       Pedido[]
  cierres       CierreCaja[]
  auditorias    PedidoAuditoria[]
  refreshTokens RefreshToken[]

  @@map("usuarios")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  usuarioId Int
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("refresh_tokens")
}

model Empleado {
  id            Int          @id @default(autoincrement())
  nombre        String
  apellido      String
  dni           String       @unique
  telefono      String?
  direccion     String?
  rol           Rol
  tarifaHora    Decimal      @db.Decimal(10, 2)
  activo        Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  fichajes      Fichaje[]
  liquidaciones Liquidacion[]

  @@map("empleados")
}

model Fichaje {
  id         Int       @id @default(autoincrement())
  empleadoId Int
  entrada    DateTime
  salida     DateTime?
  fecha      DateTime  @db.Date
  createdAt  DateTime  @default(now())
  empleado   Empleado  @relation(fields: [empleadoId], references: [id])

  @@index([empleadoId, fecha])
  @@map("fichajes")
}

model Liquidacion {
  id            Int       @id @default(autoincrement())
  empleadoId    Int
  periodoDesde  DateTime  @db.Date
  periodoHasta  DateTime  @db.Date
  horasTotales  Decimal   @db.Decimal(10, 2)
  tarifaHora    Decimal   @db.Decimal(10, 2)
  subtotal      Decimal   @db.Decimal(10, 2)
  descuentos    Decimal   @default(0) @db.Decimal(10, 2)
  adicionales   Decimal   @default(0) @db.Decimal(10, 2)
  totalPagar    Decimal   @db.Decimal(10, 2)
  observaciones String?
  pagado        Boolean   @default(false)
  fechaPago     DateTime?
  createdAt     DateTime  @default(now())
  empleado      Empleado  @relation(fields: [empleadoId], references: [id])

  @@index([empleadoId])
  @@map("liquidaciones")
}

model Mesa {
  id          Int         @id @default(autoincrement())
  numero      Int         @unique
  zona        String?
  capacidad   Int         @default(4)
  estado      EstadoMesa  @default(LIBRE)
  activa      Boolean     @default(true)
  posX        Int?
  posY        Int?
  rotacion    Int         @default(0)
  grupoMesaId Int?
  qrToken     String      @default(uuid()) @unique
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  pedidos     Pedido[]
  reservas    Reserva[]

  @@index([estado])
  @@index([zona, activa])
  @@index([grupoMesaId])
  @@map("mesas")
}

model Reserva {
  id               Int           @id @default(autoincrement())
  mesaId           Int
  clienteNombre    String
  clienteTelefono  String?
  fechaHora        DateTime
  cantidadPersonas Int
  estado           EstadoReserva @default(CONFIRMADA)
  observaciones    String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  mesa             Mesa          @relation(fields: [mesaId], references: [id])

  @@index([fechaHora])
  @@index([mesaId, fechaHora])
  @@index([estado])
  @@map("reservas")
}

model Categoria {
  id          Int      @id @default(autoincrement())
  nombre      String   @unique
  descripcion String?
  orden       Int      @default(0)
  activa      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  productos   Producto[]

  @@map("categorias")
}

model Producto {
  id                       Int                    @id @default(autoincrement())
  nombre                   String
  descripcion              String?
  precio                   Decimal                @db.Decimal(10, 2)
  imagen                   String?
  categoriaId              Int
  disponible               Boolean                @default(true)
  destacado                Boolean                @default(false)
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt
  productoBaseId           Int?
  nombreVariante           String?
  multiplicadorInsumos     Decimal                @default(1.0) @db.Decimal(3, 1)
  ordenVariante            Int                    @default(0)
  esVariantePredeterminada Boolean                @default(false)
  categoria                Categoria              @relation(fields: [categoriaId], references: [id])
  ingredientes             ProductoIngrediente[]
  pedidoItems              PedidoItem[]
  modificadores            ProductoModificador[]
  productoBase             Producto?              @relation("ProductoVariantes", fields: [productoBaseId], references: [id], onDelete: SetNull)
  variantes                Producto[]             @relation("ProductoVariantes")

  @@index([categoriaId])
  @@index([productoBaseId])
  @@index([disponible])
  @@map("productos")
}

model Modificador {
  id        Int                     @id @default(autoincrement())
  nombre    String                  @unique
  precio    Decimal                 @default(0) @db.Decimal(10, 2)
  tipo      TipoModificador
  activo    Boolean                 @default(true)
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt
  productos ProductoModificador[]
  items     PedidoItemModificador[]

  @@map("modificadores")
}

model ProductoModificador {
  id            Int         @id @default(autoincrement())
  productoId    Int
  modificadorId Int
  producto      Producto    @relation(fields: [productoId], references: [id], onDelete: Cascade)
  modificador   Modificador @relation(fields: [modificadorId], references: [id], onDelete: Cascade)

  @@unique([productoId, modificadorId])
  @@index([productoId])
  @@index([modificadorId])
  @@map("producto_modificadores")
}

model Ingrediente {
  id           Int                @id @default(autoincrement())
  nombre       String             @unique
  unidad       String
  stockActual  Decimal            @db.Decimal(10, 3)
  stockMinimo  Decimal            @db.Decimal(10, 3)
  costo        Decimal?           @db.Decimal(10, 2)
  activo       Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  productos    ProductoIngrediente[]
  movimientos  MovimientoStock[]
  lotes        LoteStock[]

  @@map("ingredientes")
}

model ProductoIngrediente {
  id            Int         @id @default(autoincrement())
  productoId    Int
  ingredienteId Int
  cantidad      Decimal     @db.Decimal(10, 3)
  producto      Producto    @relation(fields: [productoId], references: [id], onDelete: Cascade)
  ingrediente   Ingrediente @relation(fields: [ingredienteId], references: [id])

  @@unique([productoId, ingredienteId])
  @@index([productoId])
  @@index([ingredienteId])
  @@map("producto_ingredientes")
}

model MovimientoStock {
  id            Int                  @id @default(autoincrement())
  ingredienteId Int
  loteStockId   Int?
  tipo          TipoMovimientoStock
  cantidad      Decimal              @db.Decimal(10, 3)
  motivo        String?
  pedidoId      Int?
  createdAt     DateTime             @default(now())
  ingrediente    Ingrediente         @relation(fields: [ingredienteId], references: [id])
  loteStock      LoteStock?          @relation(fields: [loteStockId], references: [id], onDelete: SetNull)
  pedido         Pedido?             @relation(fields: [pedidoId], references: [id])

  @@index([ingredienteId])
  @@index([loteStockId])
  @@index([createdAt])
  @@index([pedidoId])
  @@map("movimientos_stock")
}

model Pedido {
  id                Int                @id @default(autoincrement())
  tipo              TipoPedido
  estado            EstadoPedido       @default(PENDIENTE)
  mesaId            Int?
  usuarioId         Int?
  clienteNombre     String?
  clienteTelefono   String?
  clienteDireccion  String?
  clienteEmail      String?
  tipoEntrega       TipoEntrega?
  costoEnvio        Decimal            @default(0) @db.Decimal(10, 2)
  subtotal          Decimal            @db.Decimal(10, 2)
  descuento         Decimal            @default(0) @db.Decimal(10, 2)
  total             Decimal            @db.Decimal(10, 2)
  observaciones     String?
  estadoPago        EstadoPago         @default(PENDIENTE)
  origen            OrigenPedido       @default(INTERNO)
  impreso           Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  mesa              Mesa?              @relation(fields: [mesaId], references: [id])
  usuario           Usuario?           @relation(fields: [usuarioId], references: [id])
  items             PedidoItem[]
  pagos             Pago[]
  auditorias        PedidoAuditoria[]
  comprobanteFiscal ComprobanteFiscal?
  movimientos       MovimientoStock[]
  printJobs         PrintJob[]

  @@index([estado])
  @@index([tipo])
  @@index([createdAt])
  @@index([estadoPago, createdAt])
  @@index([mesaId])
  @@index([usuarioId])
  @@map("pedidos")
}

model PedidoItem {
  id             Int                     @id @default(autoincrement())
  pedidoId       Int
  productoId     Int
  cantidad       Int
  precioUnitario Decimal                 @db.Decimal(10, 2)
  subtotal       Decimal                 @db.Decimal(10, 2)
  observaciones  String?
  createdAt      DateTime                @default(now())
  pedido         Pedido                  @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  producto       Producto                @relation(fields: [productoId], references: [id])
  modificadores  PedidoItemModificador[]

  @@index([pedidoId])
  @@index([productoId])
  @@map("pedido_items")
}

model PedidoItemModificador {
  id            Int         @id @default(autoincrement())
  pedidoItemId  Int
  modificadorId Int
  precio        Decimal     @db.Decimal(10, 2)
  pedidoItem    PedidoItem  @relation(fields: [pedidoItemId], references: [id], onDelete: Cascade)
  modificador   Modificador @relation(fields: [modificadorId], references: [id])

  @@index([pedidoItemId])
  @@index([modificadorId])
  @@map("pedido_item_modificadores")
}

model Pago {
  id                       Int                      @id @default(autoincrement())
  pedidoId                 Int
  monto                    Decimal                  @db.Decimal(10, 2)
  metodo                   MetodoPago
  canalCobro               CanalCobro               @default(CAJA)
  estado                   EstadoPago               @default(PENDIENTE)
  referencia               String?
  comprobante              String?
  propinaMonto             Decimal                  @default(0) @db.Decimal(10, 2)
  propinaMetodo            MetodoPago?
  mpPreferenceId           String?
  mpPaymentId              String?
  montoAbonado             Decimal?                 @db.Decimal(10, 2)
  vuelto                   Decimal?                 @db.Decimal(10, 2)
  idempotencyKey           String?                  @unique
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt
  pedido                   Pedido                   @relation(fields: [pedidoId], references: [id])
  transaccionesMercadoPago TransaccionMercadoPago[]

  @@index([pedidoId])
  @@index([estado])
  @@index([estado, createdAt])
  @@index([pedidoId, createdAt])
  @@index([mpPaymentId])
  @@map("pagos")
}

model PedidoAuditoria {
  id              Int      @id @default(autoincrement())
  pedidoId        Int
  usuarioId       Int?
  accion          String
  motivo          String?
  snapshotAntes   Json?
  snapshotDespues Json?
  createdAt       DateTime @default(now())
  pedido          Pedido   @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  usuario         Usuario? @relation(fields: [usuarioId], references: [id], onDelete: SetNull)

  @@index([pedidoId, createdAt])
  @@index([usuarioId])
  @@map("pedido_auditorias")
}

model CierreCaja {
  id             Int        @id @default(autoincrement())
  usuarioId      Int
  fecha          DateTime   @db.Date
  horaApertura   DateTime
  horaCierre     DateTime?
  fondoInicial   Decimal    @db.Decimal(10, 2)
  totalEfectivo  Decimal    @default(0) @db.Decimal(10, 2)
  totalTarjeta   Decimal    @default(0) @db.Decimal(10, 2)
  totalMP        Decimal    @default(0) @db.Decimal(10, 2)
  efectivoFisico Decimal?   @db.Decimal(10, 2)
  diferencia     Decimal?   @db.Decimal(10, 2)
  estado         EstadoCaja @default(ABIERTO)
  observaciones  String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  usuario        Usuario    @relation(fields: [usuarioId], references: [id])

  @@index([fecha])
  @@index([usuarioId, fecha])
  @@index([estado, createdAt])
  @@map("cierres_caja")
}

model PrintJob {
  id            Int            @id @default(autoincrement())
  pedidoId      Int
  tipo          TipoComanda
  status        EstadoPrintJob @default(PENDIENTE)
  intentos      Int            @default(0)
  maxIntentos   Int            @default(3)
  nextAttemptAt DateTime       @default(now())
  lastError     String?
  contenido     String
  anchoMm       Int            @default(80)
  batchId       String
  claimedBy     String?
  claimedAt     DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  pedido        Pedido         @relation(fields: [pedidoId], references: [id], onDelete: Cascade)

  @@index([status, nextAttemptAt])
  @@index([status, claimedAt])
  @@index([pedidoId, batchId])
  @@unique([pedidoId, tipo, batchId])
  @@map("print_jobs")
}

model Configuracion {
  id        Int      @id @default(autoincrement())
  clave     String   @unique
  valor     String
  updatedAt DateTime @updatedAt

  @@map("configuraciones")
}

model ClienteFiscal {
  id              Int                @id @default(autoincrement())
  nombre          String
  tipoDocumento   String?
  numeroDocumento String?
  cuit            String?
  condicionIva    String?
  email           String?
  domicilioFiscal String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  comprobantes    ComprobanteFiscal[]

  @@index([cuit])
  @@map("clientes_fiscales")
}

model PuntoVentaFiscal {
  id           Int                @id @default(autoincrement())
  puntoVenta   Int                @unique
  descripcion  String?
  ambiente     String             @default("homologacion")
  cuitEmisor   String?
  activo       Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  comprobantes ComprobanteFiscal[]

  @@index([activo])
  @@map("puntos_venta_fiscales")
}

model ComprobanteFiscal {
  id                 Int                @id @default(autoincrement())
  pedidoId           Int                @unique
  clienteFiscalId    Int?
  puntoVentaFiscalId Int?
  tipoComprobante    String
  numeroComprobante  String?
  cae                String?
  caeVencimiento     DateTime?
  estado             String             @default("BORRADOR")
  observaciones      String?
  payload            Json?
  respuestaArca      Json?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  pedido             Pedido             @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  clienteFiscal      ClienteFiscal?     @relation(fields: [clienteFiscalId], references: [id], onDelete: SetNull)
  puntoVentaFiscal   PuntoVentaFiscal?  @relation(fields: [puntoVentaFiscalId], references: [id], onDelete: SetNull)

  @@index([estado, createdAt])
  @@index([clienteFiscalId])
  @@index([puntoVentaFiscalId])
  @@map("comprobantes_fiscales")
}

model LoteStock {
  id                            Int                @id @default(autoincrement())
  ingredienteId                 Int
  codigoLote                    String
  stockInicial                  Decimal            @db.Decimal(10, 3)
  stockActual                   Decimal            @db.Decimal(10, 3)
  costoUnitario                 Decimal?           @db.Decimal(10, 2)
  fechaIngreso                  DateTime           @default(now())
  fechaVencimiento              DateTime?
  ultimaNotificacionVencimiento DateTime?
  activo                        Boolean            @default(true)
  createdAt                     DateTime           @default(now())
  updatedAt                     DateTime           @updatedAt
  ingrediente                   Ingrediente        @relation(fields: [ingredienteId], references: [id], onDelete: Cascade)
  movimientos                   MovimientoStock[]

  @@index([ingredienteId, activo])
  @@index([fechaVencimiento])
  @@index([ultimaNotificacionVencimiento])
  @@unique([ingredienteId, codigoLote])
  @@map("lotes_stock")
}

model MercadoPagoConfig {
  id           Int      @id @default(1)
  accessToken  String
  refreshToken String?
  publicKey    String?
  userId       String?
  email        String?
  expiresAt    DateTime?
  isOAuth      Boolean  @default(false)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("mercadopago_configs")
}

model TransaccionMercadoPago {
  id                Int      @id @default(autoincrement())
  pagoId            Int?
  mpPaymentId       String   @unique
  mpPreferenceId    String?
  status            String
  statusDetail      String?
  amount            Decimal  @db.Decimal(10, 2)
  currency          String   @default("ARS")
  payerEmail        String?
  paymentMethod     String?
  paymentTypeId     String?
  installments      Int?
  fee               Decimal? @db.Decimal(10, 2)
  netAmount         Decimal? @db.Decimal(10, 2)
  externalReference String?
  rawData           Json?
  createdAt         DateTime @default(now())
  pago              Pago?    @relation(fields: [pagoId], references: [id])

  @@index([createdAt])
  @@index([status])
  @@index([pagoId])
  @@map("transacciones_mercadopago")
}
