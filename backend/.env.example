# ============================================
# SERVIDOR
# ============================================
PORT=3001
HOST=
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3001
# Produccion EC2 recomendada: /opt/comanda/uploads
UPLOADS_DIR=

# ============================================
# BASE DE DATOS
# ============================================
DATABASE_URL="postgresql://usuario:password@127.0.0.1:5432/comanda?schema=public"
DIRECT_URL="postgresql://usuario:password@127.0.0.1:5432/comanda?schema=public"

# ============================================
# JWT
# ============================================
JWT_SECRET=CHANGE_THIS_SECRET_IN_PRODUCTION_MIN_32_CHARS
PUBLIC_ORDER_JWT_SECRET=CHANGE_THIS_PUBLIC_ORDER_SECRET_IN_PRODUCTION_MIN_32_CHARS
JWT_EXPIRES_IN=24h
PUBLIC_ORDER_TOKEN_EXPIRES_IN=2h
PUBLIC_ORDERING_PAUSED=false
# Politica MFA:
# - development/test: desactivado por defecto.
# - production: obligatorio para ADMIN,CAJERO si MFA_REQUIRED_ROLES no se define.
# - Si se define MFA_REQUIRED_ROLES (incluso vacio), se usa ese valor literal.
# Ejemplo: MFA_REQUIRED_ROLES=ADMIN,CAJERO
MFA_REQUIRED_ROLES=
MFA_ISSUER=Comanda
MFA_TRUSTED_DEVICE_DAYS=30

# ============================================
# MERCADO PAGO
# ============================================
MERCADOPAGO_WEBHOOK_SECRET=change_this_webhook_secret
# Genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=CHANGE_THIS_RUN_THE_COMMAND_ABOVE_TO_GENERATE_64_HEX_CHARS

# Configuracion manual opcional de una sola cuenta del restaurante
MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxxx
MERCADOPAGO_PUBLIC_KEY=APP_USR-xxxx

# Solo mantener si todavia se usa OAuth para conectar la cuenta desde UI
MP_APP_ID=
MP_APP_SECRET=

# ============================================
# IMPRESION / BRIDGE
# ============================================
BRIDGE_TOKEN=CHANGE_THIS_BRIDGE_TOKEN_IN_PRODUCTION
BRIDGE_ALLOWED_IPS=127.0.0.1,::1
BRIDGE_REQUIRED=false
BRIDGE_SIGNATURE_TTL_SECONDS=120
PRINT_WIDTH_MM=80
PRINT_MAX_RETRIES=3
PRINT_BACKOFF_MS=2000
PRINT_CLAIM_TTL_MS=60000

# ============================================
# BACKUPS / AWS
# ============================================
S3_BACKUP_URI=s3://tu-bucket-comanda/backups
# Opcional: si se define, backup-db.sh tambien sincroniza /uploads al prefijo indicado
S3_UPLOADS_BACKUP_URI=s3://tu-bucket-comanda/uploads
AWS_REGION=sa-east-1

# ============================================
# EMAIL
# ============================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu-email@gmail.com
# SMTP_PASS=tu-app-password
# EMAIL_FROM=noreply@turestaurante.com

# ============================================
# ARCA / FACTURACION ELECTRONICA
# ============================================
ARCA_CUIT=
ARCA_CERT_PATH=
ARCA_KEY_PATH=
ARCA_KEY_PASSPHRASE=
ARCA_AMBIENTE=homologacion
ARCA_OPENSSL_BIN=openssl

# ============================================
# MONITOREO (Opcional)
# ============================================
SENTRY_DSN=
ALERT_WEBHOOK_URL=
