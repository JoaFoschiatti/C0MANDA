# URL del backend (incluir /api)
BRIDGE_API_URL=http://localhost:3001/api

# Secreto HMAC compartido (debe coincidir con BRIDGE_TOKEN en el .env del backend)
BRIDGE_TOKEN=

# Identificador de este bridge (default: hostname de la PC)
BRIDGE_ID=pc-caja-1

# La IP publica del local debe agregarse al BRIDGE_ALLOWED_IPS del backend/nginx
# Ejemplo backend: BRIDGE_ALLOWED_IPS=203.0.113.10,198.51.100.0/24

# Nombre exacto de la impresora en Windows (ver Dispositivos e Impresoras)
PRINTER_NAME=EPSON TM-T20III

# Adaptador de impresion: spooler (default)
PRINT_ADAPTER=spooler

# Intervalo de polling en ms (default: 2000, minimo: 500)
POLL_INTERVAL_MS=2000

# Timeout para requests HTTP en ms (default: 10000)
REQUEST_TIMEOUT_MS=10000

# La impresora puede estar conectada por USB, siempre que Windows la detecte e instale
# Si el bridge corre como servicio, la cuenta del servicio debe tener acceso a la impresora
